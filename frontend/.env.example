# Variables de Entorno - GABBYPERFUM Frontend
# Copia este archivo como .env y ajusta los valores para producción.

# URL de la API del Backend
# En desarrollo: `.env.development` usa http://localhost:3000/api automáticamente.
# En producción: define VITE_API_URL en Netlify (o crea `.env.production`).
VITE_API_URL="https://tu-backend-en-produccion.com/api"
