# Variables de Entorno - GabbyPerfum Backend
# Copia este archivo como .env y ajusta los valores.

PORT=3000
# development en local | production en el servidor desplegado
NODE_ENV=development

# Supabase → Settings → API → Project URL
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Supabase → Settings → API → service_role (secret) — NO el anon key
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Secreto para firmar los tokens JWT (mín. 32 chars)
# Generá uno: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# URL del Frontend para CORS (solo en producción; en local se usa http://localhost:5173)
FRONTEND_URL="https://tu-frontend.vercel.app"
