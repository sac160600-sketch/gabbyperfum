# Variables de Entorno - GabbyPerfum Backend
# Copia este archivo como .env y ajusta los valores para producción.

# Puerto del servidor (Recomendado dejar 3000 o el que asigne tu proveedor)
PORT=3000

# Entorno (development / production)
NODE_ENV=production

# URL de conexión a la base de datos SQL Server
# Formato: sqlserver://USER:PASSWORD@HOST:PORT/DATABASE?options
DATABASE_URL="sqlserver://localhost:1433;database=ayra_db;integratedSecurity=true;trustServerCertificate=true"

# Secreto para firmar los tokens JWT
# ⚠️ OBLIGATORIO: Debe tener al menos 32 caracteres. Genera uno seguro con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# URL del Frontend para permitir peticiones (CORS)
# Ejemplo: https://gabbyperfum.netlify.app
FRONTEND_URL=""
